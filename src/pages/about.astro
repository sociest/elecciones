---
import Layout from '../layouts/Layout.astro';
import {
  ShieldCheck,
  Target,
  Globe,
  ArrowRight,
  Database,
  Cpu,
  ArrowLeft,
} from 'lucide-react';
import { buildPath } from '../lib/utils/paths';

const pilares = [
  {
    titulo: 'Transparencia Activa',
    desc: 'Buscamos que la información pública sea realmente accesible, eliminando las barreras técnicas entre el dato y el ciudadano.',
    icon: Database,
  },
  {
    titulo: 'Rigor Científico',
    desc: 'Cada cifra y relación mostrada pasa por un proceso de validación estadística respaldado por la Sociedad Científica de Estadística.',
    icon: Cpu,
  },
  {
    titulo: 'Independencia',
    desc: 'Somos una iniciativa académica sin vinculación partidaria, enfocada estrictamente en la evidencia y la fiscalización cívica.',
    icon: ShieldCheck,
  },
];
---

<Layout title="Sobre Nosotros | Monitor 2026">
  <main
    class="min-h-screen bg-neutral-white text-primary-green font-sans antialiased pb-24"
  >
    <section
      class="bg-primary-green pt-32 pb-24 px-6 relative overflow-hidden text-center"
    >
      <div
        class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"
      >
      </div>

      <div class="max-w-4xl mx-auto relative z-10 flex flex-col items-center">
        <a
          href={buildPath('/')}
          class="inline-flex items-center gap-2 text-white/40 hover:text-white transition-colors mb-12 text-[10px] font-black uppercase tracking-widest group"
        >
          <ArrowLeft
            size={14}
            className="group-hover:-translate-x-1 transition-transform"
          />
          Volver al inicio
        </a>

        <div
          class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 rounded-full border border-white/10 backdrop-blur-md mb-8"
        >
          <Target size={12} className="text-white" />
          <span
            class="text-[10px] font-black uppercase tracking-[0.3em] text-white"
            >Nuestra Misión</span
          >
        </div>

        <h1
          class="text-6xl md:text-8xl font-black text-white tracking-tighter leading-[0.85] mb-8 italic"
        >
          Ciencia al servicio <br />
          <span class="text-white/30 not-italic text-white"
            >de la democracia.</span
          >
        </h1>
        <p
          class="text-xl text-white/50 font-medium max-w-2xl mx-auto leading-relaxed text-pretty"
        >
          Monitor 2026 es una plataforma de auditoría cívica que transforma
          datos públicos en conocimiento ciudadano para fiscalizar el proceso
          electoral subnacional.
        </p>
      </div>
    </section>

    <div class="max-w-6xl mx-auto px-6 -mt-12 relative z-20">
      <div
        class="bg-white p-12 md:p-20 rounded-[4rem] shadow-2xl shadow-primary-green/10 border border-primary-green/5"
      >
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div class="space-y-8">
            <h2
              class="text-4xl font-black tracking-tighter italic leading-none text-slate-900"
            >
              Por qué existe <br />
              <span class="opacity-40 not-italic">Monitor 2026</span>
            </h2>
            <p
              class="text-lg font-medium text-slate-700 leading-relaxed text-pretty"
            >
              Nacemos de la necesidad de contar con una herramienta
              independiente que permita rastrear la trayectoria de los
              candidatos y la veracidad de las encuestas. En un entorno saturado
              de información, Monitor 2026 actúa como un filtro científico que
              organiza los registros del OEP, INE y SIGEP en una base de
              conocimientos coherente.
            </p>
            <div class="flex items-center gap-6 pt-4">
              <div class="flex flex-col">
                <span class="text-3xl font-black">2026</span>
                <span
                  class="text-[9px] font-black uppercase tracking-widest opacity-30"
                  >Elecciones Subnacionales</span
                >
              </div>
              <div class="w-px h-12 bg-primary-green/10"></div>
              <div class="flex flex-col">
                <span class="text-3xl font-black italic">Open Data</span>
                <span
                  class="text-[9px] font-black uppercase tracking-widest opacity-30"
                  >Filosofía de Proyecto</span
                >
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-4">
            {
              pilares.map((p) => (
                <div class="p-8 bg-primary-green/5 rounded-[2.5rem] border border-primary-green/5 flex gap-6 group hover:bg-primary-green hover:text-white transition-all duration-500">
                  <div class="w-12 h-12 shrink-0 bg-primary-green text-white rounded-2xl flex items-center justify-center group-hover:bg-white group-hover:text-primary-green transition-colors">
                    <p.icon size={20} />
                  </div>
                  <div>
                    <h4 class="font-black text-sm uppercase tracking-widest mb-1 italic text-slate-900 group-hover:text-white transition-colors">
                      {p.titulo}
                    </h4>
                    <p class="text-xs font-medium text-slate-700 group-hover:text-white/80 transition-colors leading-snug">
                      {p.desc}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-6 mt-32 text-center">
      <div
        class="p-16 bg-primary-green rounded-[4rem] text-white relative overflow-hidden group"
      >
        <Globe
          className="absolute -left-10 -bottom-10 w-48 h-48 opacity-10 group-hover:scale-110 transition-transform duration-1000"
        />
        <div class="relative z-10">
          <h3
            class="text-4xl font-black tracking-tighter mb-6 italic leading-none"
          >
            Únete a la <br /> Auditoría Ciudadana.
          </h3>
          <p class="text-white/60 font-medium mb-12 max-w-sm mx-auto">
            Explora la base de conocimientos y toma una decisión informada
            basada en hechos, no en propaganda.
          </p>
          <a
            href={buildPath('/explorador')}
            class="inline-flex items-center justify-center gap-4 px-10 py-5 bg-white text-primary-green rounded-2xl font-black text-xs uppercase tracking-widest shadow-2xl hover:scale-105 transition-all"
          >
            Empezar ahora
            <ArrowRight size={18} />
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  h1,
  h2,
  h3,
  h4 {
    text-wrap: balance;
  }
</style>
