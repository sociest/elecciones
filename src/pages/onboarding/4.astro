---
import OnboardingStep from '../../components/onboarding/OnboardingStep.astro';
import {
  Rocket,
  Map,
  ArrowRight,
  Search,
  BarChart3,
  ShieldCheck,
} from 'lucide-react';
import { buildPath } from '../../lib/utils/paths';

const homePath = buildPath('/');

const resumenSecciones = [
  {
    titulo: 'Explorador',
    desc: 'Filtra candidatos por municipio y cargo.',
    icon: Search,
    color: 'bg-primary-green/5 text-primary-green',
    link: buildPath('/'),
  },
  {
    titulo: 'Mapa Global',
    desc: 'Panorama político en todo el país.',
    icon: Map,
    color: 'bg-[#cc6e4b]/10 text-[#cc6e4b]',
    link: buildPath('/mapa'),
  },
  {
    titulo: 'Encuestas',
    desc: 'Tendencia de voto y datos estadísticos.',
    icon: BarChart3,
    color: 'bg-primary-green/5 text-primary-green',
    link: buildPath('/encuestas'),
  },
];
---

<OnboardingStep step={4} totalSteps={4} title="Inicio" eyebrow="Finalizar">
  <div slot="left-content" class="md:pr-4">
    <h1
      class="text-5xl sm:text-6xl font-black text-white leading-none tracking-tighter mb-3 italic"
    >
      Todo <br />
      <span class="text-white/20 not-italic">Listo.</span>
    </h1>
    <p
      class="text-white/40 text-sm md:text-base font-medium leading-snug text-pretty"
    >
      La plataforma está configurada para tu fiscalización ciudadana.
    </p>
  </div>

  <div slot="left-features" class="mt-4">
    <div class="flex items-center gap-2 text-white/60">
      <div class="p-1.5 bg-white/5 rounded-lg border border-white/10">
        <ShieldCheck size={14} />
      </div>
      <span class="text-[8px] font-black uppercase tracking-widest"
        >Información Verificada</span
      >
    </div>
  </div>

  <div slot="background-icon" class="opacity-5">
    <Rocket size={320} strokeWidth={0.5} className="text-white" />
  </div>

  <div slot="right-content" class="flex flex-col gap-6">
    <div>
      <h2
        class="text-xl font-black text-primary-green tracking-tight mb-1 italic"
      >
        ¿Qué explorar primero?
      </h2>
      <p
        class="text-[#2d160d]/40 text-[9px] font-black uppercase tracking-[0.2em]"
      >
        Herramientas disponibles
      </p>
    </div>

    <div class="grid grid-cols-1 gap-2">
      {
        resumenSecciones.map((sec) => (
          <a
            href={sec.link}
            class="flex items-center gap-4 p-3.5 bg-white border border-primary-green/5 rounded-[1.5rem] shadow-sm hover:border-primary-green/20 transition-all group cursor-pointer"
          >
            <div
              class={`w-10 h-10 shrink-0 ${sec.color} rounded-xl flex items-center justify-center group-hover:scale-105 transition-transform`}
            >
              <sec.icon size={18} />
            </div>
            <div class="space-y-0.5">
              <h4 class="text-[9px] font-black uppercase tracking-widest text-primary-green italic">
                {sec.titulo}
              </h4>
              <p class="text-[11px] font-medium text-[#2d160d]/50 leading-tight">
                {sec.desc}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>

  <div slot="actions" class="mt-6">
    <button
      id="finish-onboarding-btn"
      class="w-full group bg-primary-green text-white p-4.5 rounded-[1.5rem] font-black text-[11px] uppercase tracking-[0.2em] flex items-center justify-between shadow-lg shadow-primary-green/10 hover:scale-[1.01] transition-all cursor-pointer hover:bg-primary-green/90"
    >
      <span>EMPEZAR EXPLORACIÓN</span>
      <ArrowRight
        size={18}
        className="group-hover:translate-x-1 transition-transform"
      />
    </button>

    <div class="mt-4 text-center">
      <span
        class="text-[7px] font-black uppercase tracking-[0.4em] text-[#2d160d]/20 italic"
      >
        Monitor Electoral 2026
      </span>
    </div>
  </div>
</OnboardingStep>

<script define:vars={{ homePath }}>
  const finishBtn = document.getElementById('finish-onboarding-btn');
  if (finishBtn) {
    finishBtn.addEventListener('click', () => {
      localStorage.setItem('onboarding_completed', 'true');
      window.location.href = homePath;
    });
  }
</script>

<style>
  [slot='right-content'] .grid > a {
    animation: fadeInSlide 0.5s ease-out forwards;
    opacity: 0;
  }

  [slot='right-content'] .grid > a:nth-child(1) {
    animation-delay: 0.1s;
  }
  [slot='right-content'] .grid > a:nth-child(2) {
    animation-delay: 0.15s;
  }
  [slot='right-content'] .grid > a:nth-child(3) {
    animation-delay: 0.2s;
  }

  @keyframes fadeInSlide {
    from {
      transform: translateY(8px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>
