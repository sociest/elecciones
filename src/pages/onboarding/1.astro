---
import OnboardingStep from '../../components/onboarding/OnboardingStep.astro';
import { ShieldCheck, Zap, Fingerprint, ArrowRight } from 'lucide-react';
import { buildPath } from '../../lib/utils/paths';
---

<OnboardingStep
  step={1}
  totalSteps={4}
  title="Bienvenido"
  eyebrow="Introducción"
>
  <div slot="left-content">
    <h1
      class="text-5xl sm:text-6xl md:text-7xl font-black text-white leading-[0.9] tracking-tighter mb-6 italic"
    >
      Tu Voto <br />
      <span class="opacity-20 not-italic">Local.</span>
    </h1>
    <p
      class="text-white/40 text-base md:text-lg max-w-sm font-medium leading-relaxed"
    >
      Información clara para elegir a tus representantes en las elecciones
      subnacionales 2026.
    </p>
  </div>

  <div slot="left-features" class="space-y-4">
    <div class="flex items-center gap-3 text-white/50">
      <div class="p-2 bg-white/5 rounded-xl border border-white/10">
        <ShieldCheck size={18} />
      </div>
      <span class="text-xs font-bold uppercase tracking-widest"
        >Datos Verificados</span
      >
    </div>
    <div class="flex items-center gap-3 text-white/50">
      <div class="p-2 bg-white/5 rounded-xl border border-white/10">
        <Zap size={18} />
      </div>
      <span class="text-xs font-bold uppercase tracking-widest"
        >Actualización Real-time</span
      >
    </div>
  </div>

  <div slot="background-icon" class="opacity-5 scale-110">
    <Fingerprint size={460} strokeWidth={0.5} color="white" />
  </div>

  <div slot="right-content">
    <h2
      class="text-2xl sm:text-3xl font-black text-primary-green tracking-tight leading-tight mb-4 italic"
    >
      Conoce a tus futuros gobernantes
    </h2>
    <p
      class="text-[#2d160d]/60 font-medium text-sm leading-relaxed text-pretty"
    >
      En estas elecciones elegiremos a nuestros próximos Alcaldes, Gobernadores
      y Concejales. Hemos diseñado esta herramienta para simplificar tu
      decisión.
    </p>
  </div>

  <div slot="actions" class="mt-8">
    <a
      href={buildPath('/onboarding/2')}
      class="w-full group bg-primary-green text-white p-6 rounded-[1.5rem] font-black text-xs uppercase tracking-[0.2em] flex items-center justify-between shadow-xl shadow-primary-green/20 hover:scale-[1.02] transition-all hover:bg-primary-green/90"
    >
      <span>Siguiente paso</span>
      <ArrowRight className="group-hover:translate-x-2 transition-transform" />
    </a>
  </div>
</OnboardingStep>
