---
import OnboardingStep from '../../components/onboarding/OnboardingStep.astro';
import { ShieldCheck, ScrollText, ArrowRight } from 'lucide-react';
import { buildPath } from '../../lib/utils/paths';
---

<OnboardingStep
  step={3}
  totalSteps={4}
  title="Confianza"
  eyebrow="Transparencia"
>
  <div slot="left-content">
    <h1
      class="text-5xl sm:text-6xl md:text-7xl font-black text-white leading-[0.9] tracking-tighter mb-6 italic"
    >
      Datos <br />
      <span class="text-white/20 not-italic">Reales.</span>
    </h1>
    <p
      class="text-white/40 text-base md:text-lg max-w-sm font-medium leading-relaxed text-pretty"
    >
      Sin rumores. Información conectada directamente a fuentes oficiales de
      auditoría cívica.
    </p>
  </div>

  <div slot="left-features" class="space-y-4">
    <div class="flex items-center gap-3 text-white/50">
      <div class="p-2 bg-white/5 rounded-xl border border-white/10">
        <ShieldCheck size={18} />
      </div>
      <span class="text-xs font-bold uppercase tracking-widest text-white/60"
        >Fuente Oficial</span
      >
    </div>
    <div class="flex items-center gap-3 text-white/50">
      <div class="p-2 bg-white/5 rounded-xl border border-white/10">
        <ScrollText size={18} />
      </div>
      <span class="text-xs font-bold uppercase tracking-widest text-white/60"
        >Historial Auditado</span
      >
    </div>
  </div>

  <div slot="background-icon" class="opacity-5 scale-110">
    <ShieldCheck size={460} strokeWidth={0.5} className="text-white" />
  </div>

  <div slot="right-content">
    <div class="relative space-y-8">
      <h2
        class="text-2xl sm:text-3xl font-black text-primary-green tracking-tight leading-tight italic"
      >
        Transparencia total
      </h2>
      <p
        class="text-[#2d160d]/60 font-medium text-sm leading-relaxed text-pretty"
      >
        Lo que ves aquí no son rumores. Cada dato está vinculado a fuentes
        oficiales como el Órgano Electoral Plurinacional y el INE.
      </p>
      <div
        class="p-4 bg-primary-green/5 rounded-2xl border border-primary-green/10"
      >
        <p
          class="text-[10px] font-bold text-primary-green/70 uppercase tracking-widest leading-snug"
        >
          Mantenemos un registro histórico de cada cambio para garantizar la
          integridad de la base de conocimientos.
        </p>
      </div>
    </div>
  </div>

  <div slot="actions" class="mt-10">
    <a
      href={buildPath('/onboarding/4')}
      class="w-full group bg-primary-green text-white p-6 rounded-[1.5rem] font-black text-xs uppercase tracking-[0.2em] flex items-center justify-between shadow-xl shadow-primary-green/20 hover:scale-[1.02] active:scale-[0.98] transition-all hover:bg-primary-green/90"
    >
      <span>Siguiente paso</span>
      <ArrowRight className="group-hover:translate-x-2 transition-transform" />
    </a>
  </div>
</OnboardingStep>
