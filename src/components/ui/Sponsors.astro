---
import { buildPath } from '../../lib/utils/paths';

interface Props {
  isLight?: boolean;
}

const { isLight = false } = Astro.props;

const sponsors = [
  {
    name: 'SOCIEST',
    logo: buildPath('/logos/sociest.png'),
    logoWebp: buildPath('/logos/sociest.webp'),
    logoAvif: buildPath('/logos/sociest.avif'),
  },
  {
    name: 'Fundación ARU',
    logo: buildPath('/logos/aru.png'),
    logoWebp: buildPath('/logos/aru.webp'),
    logoAvif: buildPath('/logos/aru.avif'),
  },
  {
    name: 'LABTECNOSOCIAL',
    logo: isLight
      ? buildPath('/logos/labtecnosocial_black.png')
      : buildPath('/logos/labtecnosocial_white.png'),
    logoWebp: isLight
      ? buildPath('/logos/labtecnosocial_black.webp')
      : buildPath('/logos/labtecnosocial_white.webp'),
    logoAvif: isLight
      ? buildPath('/logos/labtecnosocial_black.avif')
      : buildPath('/logos/labtecnosocial_white.avif'),
  },
];
---

<section class="mt-8">
  <div class="space-y-4">
    <p
      class={`text-[10px] uppercase tracking-[0.3em] font-bold ${isLight ? 'text-primary-green/60' : 'text-hunter/40'}`}
    >
      Desarrollado por:
    </p>
    <div
      class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 items-center"
    >
      {
        sponsors.map((sponsor) => (
          <div class="flex flex-col items-center group cursor-pointer">
            <div
              class={`w-full h-20 flex items-center justify-center p-4 backdrop-blur-md border rounded-2xl transition-all duration-500 shadow-xl shadow-black/10 relative overflow-hidden ${isLight ? 'bg-primary-green/90 border-primary-green/10 group-hover:bg-primary-green/10 group-hover:border-primary-green/20' : 'bg-white/5 border-white/5 group-hover:bg-white/10 group-hover:border-white/10'}`}
            >
              <div class="absolute inset-0 bg-linear-to-br from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              {sponsor.logoAvif || sponsor.logoWebp ? (
                <picture>
                  {sponsor.logoAvif && (
                    <source srcset={sponsor.logoAvif} type="image/avif" />
                  )}
                  {sponsor.logoWebp && (
                    <source srcset={sponsor.logoWebp} type="image/webp" />
                  )}
                  <img
                    src={sponsor.logo}
                    alt={`Logo de ${sponsor.name}`}
                    width={
                      sponsor.name === 'SOCIEST'
                        ? 2048
                        : sponsor.name === 'Fundación ARU'
                          ? 2259
                          : 1000
                    }
                    height={
                      sponsor.name === 'SOCIEST'
                        ? 2047
                        : sponsor.name === 'Fundación ARU'
                          ? 946
                          : 496
                    }
                    class="max-h-full max-w-full object-contain filter grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 relative z-10"
                    loading="lazy"
                  />
                </picture>
              ) : (
                <img
                  src={sponsor.logo}
                  alt={`Logo de ${sponsor.name}`}
                  width={
                    sponsor.name === 'SOCIEST'
                      ? 2048
                      : sponsor.name === 'Fundación ARU'
                        ? 2259
                        : 1000
                  }
                  height={
                    sponsor.name === 'SOCIEST'
                      ? 2047
                      : sponsor.name === 'Fundación ARU'
                        ? 946
                        : 496
                  }
                  class="max-h-full max-w-full object-contain filter grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 relative z-10"
                  loading="lazy"
                />
              )}
            </div>
            <span
              class={`mt-3 text-[10px] font-bold uppercase tracking-widest transition-colors duration-500 ${isLight ? 'text-primary-green/60 group-hover:text-primary-green' : 'text-hunter/40 group-hover:text-hunter/80'}`}
            >
              {sponsor.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
